# Apex Agents — environment variable template
# Copy this file to .env.local and fill in real values.
# See docs/ENVIRONMENT-VARIABLES.md for the full checklist and how to
# generate secrets. Never commit .env.local or real credentials.

# ── Database (required) ──────────────────────────────────────────────
# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ── Authentication (required) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your_secret_here"
# Admin user ID for AI Admin access
OWNER_OPEN_ID="your_admin_user_id"
# Secret for the admin plan-upgrade endpoint
ADMIN_UPGRADE_SECRET="your_secret_here"

# ── AI services ──────────────────────────────────────────────────────
# OpenAI API key (required for AGI and AI Admin)
OPENAI_API_KEY="sk-..."
# Anthropic API key (optional, for Claude models)
ANTHROPIC_API_KEY="sk-ant-..."

# ── Pinecone (optional, for vector search / knowledge base) ──────────
PINECONE_API_KEY="..."
PINECONE_ENVIRONMENT="..."
PINECONE_INDEX="apex-agents"

# ── Stripe (optional, for subscriptions) ─────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
STRIPE_PREMIUM_YEARLY_PRICE_ID="price_..."

# ── Email (optional, Resend) ─────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ── Monitoring (optional, Sentry) ────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://...@o....ingest.sentry.io/..."
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="apex-agents-production"
SENTRY_AUTH_TOKEN="sntrys_..."

# ── GitHub (optional, for AI Admin GitHub integration) ───────────────
GITHUB_TOKEN="ghp_..."
GITHUB_OWNER="your-username"
GITHUB_REPO="apex-agents"

# ── App configuration ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
